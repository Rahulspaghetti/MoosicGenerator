# Copy this file to `.env` in the repo root and fill in real values.
# `.env` is git-ignored — never commit real secrets.

# --- Spotify OAuth (Authorization Code + PKCE) ---
# https://developer.spotify.com/dashboard -> your app -> Settings
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# The FRONTEND /callback route (Angular reads code/state, then calls the backend).
# Must exactly match a Redirect URI registered on the Spotify app, and you must
# browse the app on this same origin (http://127.0.0.1:4200) so the CSRF state
# in sessionStorage survives the redirect. Spotify requires 127.0.0.1, not localhost.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4200/callback

# --- Token encryption (OAuth tokens are encrypted at rest with Fernet) ---
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required: the app refuses to store tokens without it.
TOKEN_ENCRYPTION_KEY=

# --- ReccoBeats (optional audio-feature enrichment layer, Phase 1/2) ---
RECCOBEATS_API_KEY=

# --- Hugging Face (gated model downloads, Phase 3 MusicGen) ---
HF_TOKEN=

# --- Postgres (used to build DATABASE_URL below and by the `db` compose service) ---
POSTGRES_USER=spaghettitunes
POSTGRES_PASSWORD=spaghettitunes
POSTGRES_DB=spaghettitunes

# --- SQLAlchemy connection string ---
# When running via docker-compose, host `db` resolves to the postgres service.
# When running the API directly on your host machine, use `localhost` instead.
DATABASE_URL=postgresql+psycopg://spaghettitunes:spaghettitunes@localhost:5432/spaghettitunes

# --- Redis (Celery broker + result backend) ---
# When running via docker-compose, host `redis` resolves to the redis service.
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated browser origins allowed by CORS (Angular dev server).
FRONTEND_ORIGIN=http://127.0.0.1:4200,http://localhost:4200
